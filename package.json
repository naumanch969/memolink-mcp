{
  "name": "brinn-mcp",
  "version": "1.0.3",
  "main": "build/index.js",
  "type": "module",
  "bin": {
    "brinn-mcp": "build/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "dev": "tsx src/index.ts",
    "deploy": "wrangler deploy src/worker.ts",
    "worker:dev": "wrangler dev src/worker.ts",
    "prepare": "husky",
    "release": "npm run build && npm publish"
  },
  "lint-staged": {
    "*.ts": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "brinn",
    "research",
    "notes",
    "journaling",
    "ai-memory"
  ],
  "author": "Opstin Technologies <support.brinn@opstintechnologies.com>",
  "license": "ISC",
  "description": "Connect your AI with Brinn to manage research notes, memories, and goals using the Model Context Protocol.",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "axios": "^1.13.6",
    "dotenv": "^17.3.1",
    "hono": "^4.12.9",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.25.1"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/node": "^25.3.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.76.0"
  }
}